# ═══════════════════════════════════════════════════════════════
# Dutch Learning App — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development                    # development | staging | production

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/dutch_app
DB_MAX_CONNECTIONS=20                       # Max pool size
DB_MIN_CONNECTIONS=5                        # Min idle connections
DB_IDLE_TIMEOUT_SECS=300                   # Close idle connections after 5min
DB_MAX_LIFETIME_SECS=1800                  # Recycle connections after 30min

# ── Auth / JWT ───────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-me-in-production
JWT_EXPIRY_HOURS=24                        # Access token TTL
JWT_REFRESH_EXPIRY_DAYS=30                 # Refresh token TTL

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173      # CORS allowed origin

# ── Security ─────────────────────────────────────────────────
BCRYPT_COST=12                             # Password hash rounds (12 = ~250ms)
MAX_LOGIN_ATTEMPTS=5                       # Lock account after N failures
LOCKOUT_DURATION_MINS=15                   # Lockout duration in minutes
RATE_LIMIT_PER_SECOND=10                   # Requests per second per IP
RATE_LIMIT_BURST=30                        # Burst capacity

# ── Feature Flags ────────────────────────────────────────────
ENABLE_REGISTRATION=true                   # Allow new user registration
ENABLE_DEMO_MODE=false                     # Enable demo mode (no backend needed)

# ── Frontend (Vite) ─────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api     # Backend API URL
VITE_DEMO_MODE=true                        # Frontend demo mode
